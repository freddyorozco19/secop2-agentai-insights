// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
}

enum UserRole {
  ADMIN
  ANALISTA
  CONSULTOR
}

model Company {
  id        String   @id @default(cuid())
  nombre    String
  nit       String?
  sector    String?
  createdAt DateTime @default(now())

  users     User[]
  documents CompanyDocument[]
  analisis  AnalisisHistorico[]
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  name         String
  role         UserRole @default(ANALISTA)
  companyId    String
  company      Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  createdAt    DateTime @default(now())

  @@index([companyId])
}

enum DocumentType {
  PERFIL_FINANCIERO
  CERTIFICACION
  HOJA_DE_VIDA
  EXPERIENCIA
  JURIDICO
  OTRO
}

enum IndexStatus {
  PENDIENTE
  INDEXANDO
  INDEXADO
  ERROR
}

model CompanyDocument {
  id            String       @id @default(cuid())
  tenantId      String
  company       Company      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  nombre        String
  tipo          DocumentType
  archivoUrl    String
  textoExtraido String?
  indexStatus   IndexStatus  @default(PENDIENTE)
  chunksIndexed Int          @default(0)
  errorMensaje  String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([tenantId])
  @@index([tenantId, tipo])
}

enum ModoAnalisis {
  RAG
  DUMMY
}

enum ResultadoAplicacion {
  PENDIENTE
  GANADO
  PERDIDO
  NO_APLICO
}

model AnalisisHistorico {
  id            String              @id @default(cuid())
  tenantId      String
  company       Company             @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  procesoObjeto String
  valorEstimado Float
  puntaje       Int
  nivel         String
  modoAnalisis  ModoAnalisis
  brechasJson   String
  seAplico      Boolean             @default(false)
  resultado     ResultadoAplicacion @default(PENDIENTE)
  notas         String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt

  @@index([tenantId])
  @@index([tenantId, createdAt])
  @@index([tenantId, resultado])
}
